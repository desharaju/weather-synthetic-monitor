# OpenWeatherMap API key — get one free at https://openweathermap.org/api
WEATHER_API_KEY=your_api_key_here

# How often to run checks (in seconds). Default: 60
CHECK_INTERVAL_SECONDS=60

# Response time threshold for alerts (ms). Default: 3000
ALERT_THRESHOLD_MS=3000

# Server port. Default: 3000
PORT=3000

# City to monitor. Default: London
MONITOR_CITY=London
